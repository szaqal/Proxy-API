<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <!-- Console appender for JSON output -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <!-- Custom field for service name -->
            <customFields>{"service_name":"proxy-api"}</customFields>
            
            <!-- Timestamp format -->
            <timestampPattern>yyyy-MM-dd'T'HH:mm:ss.SSSZ</timestampPattern>
            
            <!-- Include logger name and level -->
            <includeLoggerName>true</includeLoggerName>
            <includeLevel>true</includeLevel>
            <includeThreadName>true</includeThreadName>
            <includeMessage>true</includeMessage>
            <includeException>true</includeException>
            <includeContextName>false</includeContextName>
            <includeMDC>true</includeMDC>
        </encoder>
    </appender>

    <!-- File appender for persistent logs (optional) -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/proxy-api.json</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>logs/proxy-api.%d{yyyy-MM-dd}.%i.json</fileNamePattern>
            <maxFileSize>100MB</maxFileSize>
            <maxHistory>7</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <customFields>{"service_name":"proxy-api"}</customFields>
            <timestampPattern>yyyy-MM-dd'T'HH:mm:ss.SSSZ</timestampPattern>
            <includeLoggerName>true</includeLoggerName>
            <includeLevel>true</includeLevel>
            <includeThreadName>true</includeThreadName>
            <includeMessage>true</includeMessage>
            <includeException>true</includeException>
            <includeMDC>true</includeMDC>
        </encoder>
    </appender>

    <springProfile name="default,local">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <springProfile name="prod,k8s">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
        </root>
    </springProfile>

    <!-- Application loggers -->
    <logger name="com.proxy.demo" level="DEBUG"/>
    <logger name="org.springframework.web" level="INFO"/>
    <logger name="org.springframework.boot.actuate" level="INFO"/>
    <logger name="io.opentelemetry" level="WARN"/>

</configuration>
